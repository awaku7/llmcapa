#!/usr/bin/env python3
"""
Scrape LM Studio model catalog from https://lmstudio.ai/models

Usage: python _scrape_lmstudio.py [--save]
"""

import json
import os
import re
import sys
from playwright.sync_api import sync_playwright

OUTPUT = os.path.join(os.path.dirname(__file__), "..", "src", "llmcapa", "data", "lmstudio.json")
BASE_URL = "https://lmstudio.ai"


def extract_model_data(page, slug):
    """Extract all model data from a single LM Studio model detail page."""
    page.goto(f"{BASE_URL}{slug}", wait_until="networkidle", timeout=30000)
    page.wait_for_timeout(2000)

    main = page.query_selector("main") or page.query_selector("body")
    lines = main.inner_text().split("\n")
    lines = [l.strip() for l in lines if l.strip()]

    # Find the content section by locating "← All Models"
    start_idx = None
    for i, line in enumerate(lines):
        if "All Models" in line and ("←" in line or "<-" in line):
            start_idx = i
            break
    if start_idx is None:
        # Fallback: look for the first H1
        return []

    # -- Extract name (line after ← All Models) --
    name = ""
    if start_idx + 1 < len(lines):
        name = lines[start_idx + 1]

    # -- Extract downloads --
    downloads = ""
    if start_idx + 2 < len(lines):
        dl_candidate = lines[start_idx + 2]
        m = re.search(r"([\d.]+[KMB]?)\s*Downloads", dl_candidate)
        if m:
            downloads = m.group(1)

    # -- Find where model variants start (after "Models" heading) --
    # The "Models" heading appears multiple times (nav, main section, footer).
    # We want the one that appears after "← All Models" and before "Memory Requirements"
    variant_start = None
    variant_end = None
    for i in range(start_idx, len(lines)):
        if lines[i] == "Models" and variant_start is None:
            # First "Models" after the page start - but nav also has "Models"
            # Check if "Updated" appears soon after
            for j in range(i + 1, min(i + 5, len(lines))):
                if "Updated" in lines[j]:
                    variant_start = i
                    break
        if variant_start is not None and lines[i] == "Memory Requirements":
            variant_end = i
            break

    if variant_start is None:
        # Fallback: just look for the pattern directly
        for i in range(start_idx, len(lines)):
            if "/" in lines[i] and i + 3 < len(lines) and lines[i + 1].endswith("GB"):
                if not variant_start:
                    variant_start = i - 1  # The "Models" heading might be before this
                break

    # -- Extract model variants --
    variants = []
    if variant_start is not None:
        # Skip "Models" and "Updated X" to get to actual variants
        i = variant_start + 1
        while i < len(lines) and (variant_end is None or i < variant_end):
            line = lines[i]
            if "Updated" in line:
                i += 1
                continue
            # A variant model_id looks like org/model-name (contains /)
            if "/" in line and not line.startswith("To run"):
                model_id = line
                size = ""
                dl_count = ""
                if i + 1 < len(lines) and "GB" in lines[i + 1]:
                    size = lines[i + 1]
                    if i + 2 < len(lines) and lines[i + 2].isdigit():
                        dl_count = lines[i + 2]
                variants.append({
                    "model_id": model_id,
                    "size_gb": size,
                    "downloads": dl_count,
                })
                # Skip ahead (model_id, size, dl_count, "Get")
                if i + 3 < len(lines) and lines[i + 3] == "Get":
                    i += 4
                    continue
            i += 1

    # -- Extract capabilities and about sections --
    def get_section_text(heading, start_search):
        for i in range(start_search, len(lines)):
            if lines[i] == heading:
                content = []
                for j in range(i + 1, len(lines)):
                    if lines[j] in ("Product", "Download the app"):
                        break
                    if lines[j] in ("Memory Requirements", "Capabilities", "About", "License"):
                        if lines[j] != heading:
                            break
                    content.append(lines[j])
                return " ".join(content)
        return ""

    # Find the content start (past the model variants section)
    # Look for "Capabilities" heading
    cap_start = 0
    for i in range(start_idx, len(lines)):
        if lines[i] == "Capabilities":
            cap_start = i
            break
    capabilities_raw = get_section_text("Capabilities", cap_start) if cap_start else ""
    about_raw = get_section_text("About", cap_start) if cap_start else ""
    mem_raw = get_section_text("Memory Requirements", start_idx)

    # -- Determine capabilities --
    full_cap = (capabilities_raw + " " + about_raw).lower()
    supports_vision = any(w in full_cap for w in ["vision", "image", "multimodal", "video", "ocr", "visual", "object detection", "chart", "document"])
    supports_reasoning = any(w in full_cap for w in ["reasoning", "think", "step-by-step"])
    supports_function_calling = any(w in full_cap for w in ["tool use", "function calling", "tools", "function calling"])

    input_modalities = ["text"]
    if supports_vision:
        input_modalities.append("image")
    if "video" in full_cap and "video" in [w.lower() for w in capabilities_raw.split()] + [w.lower() for w in about_raw.split()]:
        input_modalities.append("video")
    if "audio" in full_cap and ("audio" in capabilities_raw.lower() or "audio" in about_raw.lower() or "speech" in capabilities_raw.lower() or "speech" in about_raw.lower()):
        input_modalities.append("audio")

    output_modalities = ["text"]

    # -- Extract context window --
    context_window = 0
    ctx_matches = re.findall(r'(\d+)\s*[Kk]\s*[Tt]oken', full_cap)
    if ctx_matches:
        context_window = max(int(m) * 1024 for m in ctx_matches)
    if not context_window:
        ctx_matches = re.findall(r'context\s*(?:window|length)?\s*(?:of\s*)?(?:up\s*to\s*)?(\d+)\s*[Kk]', full_cap)
        if ctx_matches:
            context_window = max(int(m) * 1024 for m in ctx_matches)
    if not context_window:
        # Check memory requirements
        mem_lower = mem_raw.lower()
        ctx_ram_matches = re.findall(r'(\d+)\s*gb', mem_lower)
        if ctx_ram_matches:
            gb_nums = [int(m) for m in ctx_ram_matches]
            # Approximate: if there's a 128+ GB mention, it might be 256K ctx
            pass

    # -- Extract max output tokens --
    max_output = 0
    out_matches = re.findall(r'(\d+)\s*[Kk]\s*output', full_cap)
    if out_matches:
        max_output = max(int(m) * 1024 for m in out_matches)

    # -- Build entries for each variant --
    result_variants = []
    seen_ids = set()
    for v in variants:
        mid = v["model_id"]
        if not mid or mid in seen_ids:
            continue
        seen_ids.add(mid)
        parts = mid.rsplit("/", 1)
        display = parts[-1] if len(parts) > 1 else mid

        entry = {
            "provider": "lmstudio",
            "model_id": mid,
            "display_name": display,
            "context_window": context_window,
            "max_output_tokens": max_output if max_output else 8192,
            "input_modalities": list(input_modalities),
            "output_modalities": list(output_modalities),
            "supports_function_calling": supports_function_calling,
            "supports_json_mode": True,
            "supports_streaming": True,
            "supports_vision": supports_vision,
            "supports_reasoning": supports_reasoning,
            "knowledge_cutoff": "2024-01-01",
            "pricing": {
                "input_per_1m": 0.0,
                "output_per_1m": 0.0,
                "currency": "USD"
            },
            "aliases": [],
            "deprecated": False,
            "supports_fim": False,
            "license_type": "free",
        }
        result_variants.append(entry)

    return result_variants


def main():
    save = "--save" in sys.argv

    with sync_playwright() as p:
        browser = p.chromium.launch(headless=True)
        page = browser.new_page()

        # Get all model family links
        print("Fetching model list from main page...")
        page.goto(f"{BASE_URL}/models", wait_until="networkidle", timeout=30000)
        page.wait_for_timeout(2000)
        slugs = page.evaluate("""() => {
            const links = document.querySelectorAll('a');
            const modelLinks = new Set();
            for (const link of links) {
                const href = link.getAttribute('href');
                if (href && href.startsWith('/models/') && href !== '/models') {
                    modelLinks.add(href);
                }
            }
            return Array.from(modelLinks);
        }""")
        print(f"Found {len(slugs)} model families: {slugs}")
        page.close()

        # Scrape each model family page
        all_models = []
        seen_model_ids = set()
        for idx, slug in enumerate(slugs):
            print(f"\n[{idx + 1}/{len(slugs)}] Scraping {slug}...", end="")
            try:
                spage = browser.new_page()
                variants = extract_model_data(spage, slug)
                spage.close()
                print(f" {len(variants)} variant(s)")
                for v in variants:
                    mid = v["model_id"]
                    if mid not in seen_model_ids:
                        seen_model_ids.add(mid)
                        all_models.append(v)
                    else:
                        print(f"    SKIP (duplicate): {mid}")
            except Exception as e:
                print(f" ERROR: {e}")

        browser.close()

    all_models.sort(key=lambda m: m["model_id"])
    print(f"\nTotal unique model entries: {len(all_models)}")

    output_data = {"models": all_models}

    if save:
        os.makedirs(os.path.dirname(OUTPUT), exist_ok=True)
        with open(OUTPUT, "w", encoding="utf-8") as f:
            json.dump(output_data, f, indent=2, ensure_ascii=False)
        print(f"Saved to {OUTPUT}")
    else:
        print(f"\nSample entries:")
        for m in all_models[:5]:
            print(f"  {m['model_id']:50s} | ctx={m['context_window']} | vision={m['supports_vision']} | tools={m['supports_function_calling']} | reasoning={m['supports_reasoning']}")
        print(f"\nRun with --save to write to {OUTPUT}")


if __name__ == "__main__":
    main()
